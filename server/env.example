# Render 环境变量（Dashboard → Environment）
# 多个前端域名用英文逗号分隔，例如：
# CORS_ORIGIN=https://你的项目.vercel.app,https://自定义域名.com
# 仅本地调试可设为 *（生产环境建议写明确域名）
CORS_ORIGIN=*

# 必填（生产）：随机长字符串，用于签发登录 Token
# JWT_SECRET=

# 生产（Render）：新建 PostgreSQL，填写 Internal Database URL
# DATABASE_URL=postgres://...

# 本地/无 Postgres 时：自动使用 SQLite 文件（默认 ./data/wx.db），账号与聊天记录会保存到磁盘
# SQLITE_PATH=/绝对路径/wx.db

# 仅调试：内存库（不持久化）
# USE_MEMORY_DB=1

# Render 会自动注入 PORT，本地可不设
# PORT=3001
