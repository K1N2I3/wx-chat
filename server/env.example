# Render 环境变量（Dashboard → Environment）
# 多个前端域名用英文逗号分隔，例如：
# CORS_ORIGIN=https://你的项目.vercel.app,https://自定义域名.com
# 仅本地调试可设为 *（生产环境建议写明确域名）
CORS_ORIGIN=*

# 必填（生产）：随机长字符串，用于签发登录 Token
# JWT_SECRET=

# —— 任选其一作为持久化 ——

# Firebase（推荐用 Firestore）
# 方式1：直接放 service account JSON（整串 JSON）
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# 方式2：拆分字段
# FIREBASE_PROJECT_ID=xxx
# FIREBASE_CLIENT_EMAIL=xxx@xxx.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# 仅调试：Firebase 连接失败时是否强制退出（默认自动回退）
# FIREBASE_STRICT=1

# MongoDB（Atlas 或自建）：连接串
# MONGODB_URI=mongodb+srv://user:pass@cluster.xxx.mongodb.net/?retryWrites=true&w=majority
# TLS / SSL alert 80 + ReplicaSetNoPrimary：多为 Node↔Atlas 在 Render 上的 IPv6/TLS 握手问题。
# 已默认 IPv4 优先 + 关闭 autoSelectFamily。若仍失败请依次尝试：
# 1) Atlas「Connect」里选 **Standard connection string**（mongodb://host1:27017,... 非 mongodb+srv）整段粘贴到 MONGODB_URI
# 2) Render 服务把 Node 从 20 改为 **18**（Dashboard → Environment）
# 3) 设 MONGODB_PREFER_IPV6=1 仅当你确认要用 IPv6
# 可选：数据库名（默认 wxchat）
# MONGODB_DB_NAME=wxchat
# 若只设置了 DATABASE_URL 且为 mongodb:// 或 mongodb+srv://，也会走 MongoDB

# PostgreSQL（Render 等）
# DATABASE_URL=postgres://...

# 本地默认：无上面两项时使用 SQLite 文件 ./data/wx.db
# SQLITE_PATH=/绝对路径/wx.db

# 仅调试：内存库（不持久化）
# USE_MEMORY_DB=1

# Render 会自动注入 PORT，本地可不设
# PORT=3001
